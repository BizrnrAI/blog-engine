# Blog engine environment variables. Copy to .env (never commit real values).
# Everything here is optional in the sense that the engine degrades gracefully;
# the comments say what you lose without each one.

# --- Text generation (skip entirely if you provide a generateText hook) ---
# Bearer token for the configured chat-completions endpoint.
# The env var NAME is configurable via config.text.apiKeyEnv (default below).
OPENROUTER_API_KEY=

# --- Image generation (skip if you provide a generateHeroImage hook) ---
# Vercel AI Gateway key for hero image generation. Without it, posts use the
# adapter's curated fallback photos (still local + branded OG card).
VERCEL_AI_GATEWAY_BLOG_KEY=
# Fallback key checked when the BLOG-specific key is unset.
VERCEL_AI_GATEWAY_KEY=

# --- Google Search Console (optional demand-driven topics + sitemap pings) ---
# OAuth client with webmasters scope and a refresh token for the property
# owner. Without these, topic selection uses the editorial pool only and GSC
# sitemap resubmission is skipped.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- IndexNow ---
# Overrides config.indexNow.key. The key file must be hosted at
# https://<site>/<key>.txt for submissions to count.
INDEXNOW_KEY=

# --- Operational switches (usually set by CI, not in .env) ---
# BLOG_ENGINE_DISABLED=1   # kill switch: run exits cleanly without generating
# DRY_RUN=1                # print the post instead of writing files
# SKIP_PING=1              # generate without pinging search engines (PR flows)
# BLOG_SLUGS=a,b           # slugs for the index-published CLI
# WAIT_FOR_LIVE=1          # poll production URLs before pinging
