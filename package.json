{
  "name": "@bizrnr/blog-engine",
  "version": "0.3.0",
  "description": "Canonical BizRnR autonomous blog engine for RSS, image generation, watermarking, and PR-based publishing.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "verify": "npm run typecheck && npm run test && npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.143",
    "ai": "^6.0.219",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3"
  },
  "license": "UNLICENSED"
}
